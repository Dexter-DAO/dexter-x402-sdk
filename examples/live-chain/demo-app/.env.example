# live-chain demo (buyer-side CLI) — env config

# The relay's URL. Local default.
RELAY_URL=http://localhost:4400

# The seller's pubkey — must match what the relay reports at /healthz.
# Used by the buyer SDK as the session's allowed_counterparty.
SELLER_PUBKEY=

# Solana RPC. Buyer's choice — no requirement it match the relay's.
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# The buyer's vault. From a scripted enrollment (e.g. dexter-facilitator
# /scripts/ots-e2e/enroll-test-vault.ts) — must already be funded with a
# little USDC.
BUYER_SWIG=
BUYER_VAULT_PDA=

# Path to the buyer's passkey JSON file (P-256 keypair, written by the
# scripted enroller).
PASSKEY_KEY_FILE=

# Path to a fee-payer keypair JSON. Pays Solana network fees for the
# register_session_key and revoke txs (~0.005 SOL total). NOT used for
# settlement — the facilitator covers that gas separately.
FEE_PAYER_KEY_FILE=

# Tab caps (human-readable USDC).
PER_BATCH_CAP_USDC=0.01
TOTAL_TAB_CAP_USDC=0.50

# The account the buyer wants to watch (any Solana pubkey).
WATCH_ACCOUNT=

# live-chain relay — env config
#
# Copy to .env in this directory and fill in.

# Helius RPC + Laserstream — same key powers both.
# Use mainnet.helius-rpc.com, NOT rpc.helius.xyz (legacy, returns 429 on websockets).
HELIUS_API_KEY=
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Seller identity. The seller pubkey ends up as `allowed_counterparty` in the
# buyer's session scope, so vouchers signed for this seller cannot be replayed
# elsewhere. Generate a fresh Ed25519 keypair for the demo (does NOT need any
# SOL/USDC on it — this account does not pay gas or hold funds).
SELLER_PRIVATE_KEY=

# Port for the HTTP/SSE relay.
PORT=4400

# Voucher cadence defaults. The relay uses these unless the buyer overrides
# via openTab options.
VOUCHER_BATCH_EVENTS=10
VOUCHER_BATCH_MS=500

# Per-event price. Cumulative-amount semantics: each voucher's cumulative
# total is `events_so_far * EVENT_PRICE_USDC`. Example: 0.0001 USDC per event,
# 1000 events = $0.10 total.
EVENT_PRICE_USDC=0.0001

# Total cap per tab. The seller refuses to open tabs with totalCap above this.
# Belt-and-braces safety on top of the buyer-side cap.
MAX_TAB_USDC=5.00
